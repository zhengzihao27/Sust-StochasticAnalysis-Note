\@writefile{loe}{\contentsline {mylemma}{\ifthmt@listswap Lemma~1.1.2\else \numberline {1.1.2}Lemma\fi }{3}{mylemma.2}\protected@file@percent }
\@writefile{loe}{\contentsline {mydefinition}{\ifthmt@listswap Definition~1.1.1\else \numberline {1.1.1}Definition\fi }{3}{mydefinition.1}\protected@file@percent }
\@writefile{loe}{\contentsline {myproposition}{\ifthmt@listswap Proposition~1.1.3\else \numberline {1.1.3}Proposition\fi }{3}{myproposition.3}\protected@file@percent }
